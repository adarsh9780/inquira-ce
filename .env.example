# Inquira CE environment template
# Copy this file to `.env` and fill in the real values.
#
# Naming convention:
# - `SB_INQUIRA_CE_*` is the project's canonical Supabase naming
# - `INQUIRA_*` compatibility variables are included for backend migration convenience

# ------------------------------------------------------------------------------
# Supabase project settings
# ------------------------------------------------------------------------------

# Supabase project URL
SB_INQUIRA_CE_URL=

# Safe to expose to the desktop/frontend app
SB_INQUIRA_CE_PUBLISHABLE_KEY=

# Backend-only secret. Never expose this to the desktop/frontend app.
SB_INQUIRA_CE_SERVICE_ROLE_KEY=

# Native desktop auth callback
SB_INQUIRA_CE_AUTH_REDIRECT_URI=inquira://auth/callback

# Future hosted web app/account URL
SB_INQUIRA_CE_SITE_URL=

# Comma-separated list of enabled auth methods for operator clarity only
# Example: google,microsoft,github,magic_link
SB_INQUIRA_CE_AUTH_PROVIDERS=

# ------------------------------------------------------------------------------
# Inquira auth runtime compatibility settings
# ------------------------------------------------------------------------------

# Planned auth provider switch for the backend migration
INQUIRA_AUTH_PROVIDER=supabase

# Compatibility aliases so the backend can read stable names during rollout
INQUIRA_SUPABASE_URL=${SB_INQUIRA_CE_URL}
INQUIRA_SUPABASE_PUBLISHABLE_KEY=${SB_INQUIRA_CE_PUBLISHABLE_KEY}
INQUIRA_SUPABASE_SERVICE_ROLE_KEY=${SB_INQUIRA_CE_SERVICE_ROLE_KEY}
INQUIRA_SUPABASE_AUTH_REDIRECT_URI=${SB_INQUIRA_CE_AUTH_REDIRECT_URI}
INQUIRA_SUPABASE_SITE_URL=${SB_INQUIRA_CE_SITE_URL}

# ------------------------------------------------------------------------------
# Frontend / Vite compatibility settings
# ------------------------------------------------------------------------------

# Leave empty to default to the origin serving the app unless we explicitly need overrides.
VITE_API_BASE=
VITE_WS_BASE=

# Supabase values exposed to the desktop/web frontend bundle
VITE_SB_INQUIRA_CE_URL=${SB_INQUIRA_CE_URL}
VITE_SB_INQUIRA_CE_PUBLISHABLE_KEY=${SB_INQUIRA_CE_PUBLISHABLE_KEY}
VITE_SB_INQUIRA_CE_AUTH_REDIRECT_URI=${SB_INQUIRA_CE_AUTH_REDIRECT_URI}

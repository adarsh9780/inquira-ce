{
  "name": "inquira",
  "private": true,
  "version": "0.5.35",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "export-openapi": "uv run --project ../backend python ../backend/scripts/export_openapi.py ./openapi.json",
    "generate-client": "npm run export-openapi && orval",
    "test": "npm run test:source && npm run test:runtime",
    "test:source": "node --test test/*.test.mjs",
    "test:runtime": "vitest run",
    "e2e": "playwright test",
    "e2e:list": "playwright test --list"
  },
  "dependencies": {
    "@codemirror/autocomplete": "^6.18.6",
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/search": "^6.5.11",
    "@codemirror/state": "^6.5.2",
    "@codemirror/view": "^6.38.1",
    "@headlessui/vue": "^1.7.23",
    "@heroicons/vue": "^2.2.0",
    "@tailwindcss/vite": "^4.1.11",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@vscode/markdown-it-katex": "^1.1.2",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "ag-grid-community": "^34.1.0",
    "ag-grid-vue3": "^34.1.0",
    "axios": "^1.18.1",
    "codemirror": "^6.0.2",
    "dompurify": "^3.4.11",
    "katex": "^0.16.11",
    "markdown-it": "^14.1.0",
    "pinia": "^3.0.3",
    "plotly.js-dist-min": "^3.0.3",
    "prismjs": "^1.30.0",
    "tailwindcss": "^4.1.11",
    "vue": "^3.5.17"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/test-utils": "^2.4.11",
    "happy-dom": "^20.10.2",
    "orval": "^8.18.0",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  },
  "overrides": {
    "@codemirror/matchbrackets": "npm:@codemirror/language",
    "@codemirror/rangeset": "npm:@codemirror/state",
    "@codemirror/text": "npm:@codemirror/state",
    "glob": "^12.0.0"
  },
  "allowScripts": {
    "esbuild@0.28.1": true,
    "fsevents@2.3.2": true,
    "fsevents@2.3.3": true
  }
}
